# ── 로컬 개발용 ────────────────────────────────────────────────
DATABASE_URL="postgresql://ems_user:your_secure_password@localhost:5432/education_db"
DIRECT_DATABASE_URL="postgresql://ems_user:your_secure_password@localhost:5432/education_db"

# ── Supabase 배포용 (Vercel 환경변수에 설정) ──────────────────────
# DATABASE_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:5432/postgres"

JWT_SECRET="replace_me"
JWT_REFRESH_SECRET="replace_me_too"
PORT=4000
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
CORS_ORIGIN="http://localhost:3001"
ENABLE_DASHBOARD_DEMO_SEED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
